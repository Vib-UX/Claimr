# Claimr environment variables

# ── Privy ──────────────────────────────────────────────────────────────────
# App ID is public. With no app id set, Claimr runs a polished "demo auth"
# mode (email -> mock embedded wallet) so the flow works out of the box.
# Get credentials at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# App Secret is SERVER-ONLY (no NEXT_PUBLIC_ prefix). Used by /api/claim to
# verify the user's Privy access token before minting.
PRIVY_APP_SECRET=

# ── Onchain (Monad Testnet, chain 10143) ─────────────────────────────────────
# Deployed ClaimrPOAP (ERC-721) address. When set, the claim flow mints a real
# POAP; otherwise it falls back to the mock mint.
NEXT_PUBLIC_POAP_CONTRACT_ADDRESS=

# Server-only minter private key. The backend mints POAPs to users from this
# wallet so claims are gasless for the user. Keep this secret.
MINTER_PRIVATE_KEY=

# Monad RPC endpoint.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
